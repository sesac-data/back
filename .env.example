# Incentdoc v2 local environment example
# Copy to the environment mechanism used by your runtime. Do not commit real secrets.

# OpenAI is only for policy source extraction and candidate condition structuring.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
POLICY_EXTRACTION_MODEL=gpt-4.1-mini
POLICY_EXTRACTION_PROMPT_VERSION=policy_extraction_v1

# Database URL should be supplied by environment in real deployments.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/incentive_db

# Approved policy DB loader test connection. Use a dedicated test database/schema only.
INCENTDOC_POLICY_DB_URL=postgresql://postgres:postgres@localhost:5432/incentdoc_policy_test
INCENTDOC_RUN_POLICY_DB_INTEGRATION=false

# React/Vite recommendation demo adapter.
VITE_RECOMMENDATION_ADAPTER=mock
VITE_RECOMMENDATION_API_BASE_URL=http://127.0.0.1:8000
VITE_RECOMMENDATION_POLICY_SOURCE=demo_fixture

# Policy calculation must use approved policy versions only.
POLICY_REQUIRE_APPROVAL=true

# MVP keeps user types independent.
ENABLE_GENERAL_COMPANY_LABOR_PARTNER_MATCHING=false
